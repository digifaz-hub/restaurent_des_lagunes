<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Ajout du champ traiteur_demande_id dans le formulaire sale.order -->
    <record id="view_order_form_inherit_traiteur" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.traiteur</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='client_order_ref']" position="after">
                <field name="traiteur_demande_id" invisible="not traiteur_demande_id"/>
            </xpath>
        </field>
    </record>

    <!-- Ajout du champ traiteur_prestation_id dans les lignes sale.order.line (form readonly) -->
    <record id="view_order_line_form_inherit_traiteur" model="ir.ui.view">
        <field name="name">sale.order.line.form.inherit.traiteur</field>
        <field name="model">sale.order.line</field>
        <field name="inherit_id" ref="sale.sale_order_line_view_form_readonly"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='product_id']" position="after">
                <field name="traiteur_prestation_id" invisible="not traiteur_prestation_id"/>
            </xpath>
        </field>
    </record>

    <!-- Ajout du champ traiteur_prestation_id dans la liste des lignes -->
    <record id="view_order_line_tree_inherit_traiteur" model="ir.ui.view">
        <field name="name">sale.order.line.tree.inherit.traiteur</field>
        <field name="model">sale.order.line</field>
        <field name="inherit_id" ref="sale.view_order_line_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="traiteur_prestation_id" optional="hide"/>
            </xpath>
        </field>
    </record>
</odoo>
