<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vue Liste : Types de prestations -->
    <record id="view_traiteur_type_prestation_list" model="ir.ui.view">
        <field name="name">lagunes.traiteur.type.prestation.list</field>
        <field name="model">lagunes.traiteur.type.prestation</field>
        <field name="arch" type="xml">
            <list string="Types de prestations">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="heure_service"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Vue Formulaire : Types de prestations -->
    <record id="view_traiteur_type_prestation_form" model="ir.ui.view">
        <field name="name">lagunes.traiteur.type.prestation.form</field>
        <field name="model">lagunes.traiteur.type.prestation</field>
        <field name="arch" type="xml">
            <form string="Type de prestation">
                <sheet>
                    <field name="image" widget="image" class="oe_avatar" options="{'preview_image': 'image'}"/>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="ex: Pause déjeuner"/></h1>
                        <label for="code" class="oe_edit_only"/>
                        <h3><field name="code" placeholder="ex: PDEJ"/></h3>
                    </div>
                        <group>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="active"/>
                            <field name="sequence"/>
                        </group>
                        <group string="Service">
                            <field name="heure_service"/>
                            <field name="duree_moyenne_heures" widget="float_time"/>
                        </group>
                        <group string="Design &amp; Affichage (Admin)" groups="base.group_no_one">
                            <field name="icon"/>
                            <field name="color" widget="color"/>
                        </group>

                    <notebook>
                        <page string="Niveaux / Formules" name="niveaux">
                            <field name="niveau_ids" context="{'default_type_prestation_ids': [(6, 0, [id])]}">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="is_recommended"/>
                                    <field name="active" widget="boolean_toggle"/>

                                </list>
                            </field>
                        </page>
                        <page string="Description Portail" name="description">
                            <field name="description" placeholder="Cette description sera affichée sur le site web..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action : Types de prestations -->
    <record id="action_traiteur_type_prestation" model="ir.actions.act_window">
        <field name="name">Types de prestations</field>
        <field name="res_model">lagunes.traiteur.type.prestation</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Créez votre premier type de prestation (ex: Pause-café, Cocktail).
            </p>
        </field>
    </record>
</odoo>
