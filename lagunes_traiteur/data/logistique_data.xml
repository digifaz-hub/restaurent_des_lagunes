<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Logistique par défaut -->
        <record id="logistique_nappe" model="lagunes.traiteur.logistique">
            <field name="name">Nappe blanche (tissu)</field>
            <field name="icon">fa-square-o</field>
            <field name="unite">par table</field>
            <field name="prix_unitaire">2500.0</field>
        </record>

        <record id="logistique_chaise" model="lagunes.traiteur.logistique">
            <field name="name">Chaise de réception</field>
            <field name="icon">fa-chair</field>
            <field name="unite">par chaise</field>
            <field name="prix_unitaire">500.0</field>
        </record>

        <record id="logistique_table" model="lagunes.traiteur.logistique">
            <field name="name">Table ronde (8 pers.)</field>
            <field name="icon">fa-circle-o</field>
            <field name="unite">par table</field>
            <field name="prix_unitaire">5000.0</field>
        </record>

        <record id="logistique_sono" model="lagunes.traiteur.logistique">
            <field name="name">Sono + Micro sans fil</field>
            <field name="icon">fa-microphone</field>
            <field name="unite">forfait jour</field>
            <field name="prix_unitaire">25000.0</field>
        </record>
    </data>
</odoo>
