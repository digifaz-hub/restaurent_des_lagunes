<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Action du rapport Logistique -->
    <record id="action_report_traiteur_logistique" model="ir.actions.report">
        <field name="name">Fiche Logistique / Production</field>
        <field name="model">lagunes.traiteur.demande</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">lagunes_traiteur.report_logistique_template</field>
        <field name="report_file">lagunes_traiteur.report_logistique_template</field>
        <field name="print_report_name">'Fiche Logistique - %s' % (object.reference)</field>
        <field name="binding_model_id" ref="lagunes_traiteur.model_lagunes_traiteur_demande"/>
        <field name="binding_type">report</field>
    </record>

    <!-- Template du rapport Logistique -->
    <template id="report_logistique_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page" style="font-family: 'Helvetica', 'Arial', sans-serif;">
                        
                        <div class="row mb-4" style="border-bottom: 2px solid #000; padding-bottom: 10px;">
                            <div class="col-8">
                                <h2 class="fw-bold">FICHE DE PRODUCTION &amp; LOGISTIQUE</h2>
                                <h4 class="text-primary"><t t-esc="o.reference"/> — <t t-esc="o.nom_entreprise"/></h4>
                            </div>
                            <div class="col-4 text-end">
                                <div class="badge bg-dark text-white p-2 h4">
                                    <t t-esc="o.nb_personnes"/> CONVIVES
                                </div>
                            </div>
                        </div>

                        <div class="row mb-5">
                            <div class="col-6">
                                <h5 class="fw-bold border-bottom">Informations Clés</h5>
                                <strong>Date de service :</strong> <span t-field="o.date_debut"/> au <span t-field="o.date_fin"/><br/>
                                <strong>Heure de service :</strong> <span t-field="o.type_prestation_id.heure_service"/><br/>
                                <strong>Lieu :</strong> <span t-field="o.adresse_prestation"/>
                            </div>
                            <div class="col-6">
                                <h5 class="fw-bold border-bottom">Contact Terrain</h5>
                                <strong>Nom :</strong> <span t-field="o.prenom_contact"/> <span t-field="o.nom_contact"/><br/>
                                <strong>Téléphone :</strong> <span t-field="o.telephone_contact"/>
                            </div>
                        </div>

                        <!-- Section Cuisine -->
                        <h4 class="bg-light p-2 fw-bold mb-3"><i class="fa fa-fire me-2"/> À PRÉPARER (CUISINE)</h4>
                        <t t-foreach="o.jour_ids" t-as="jour">
                            <div class="mb-4">
                                <h5 class="fw-bold text-primary"><t t-esc="jour.jour_semaine"/> <t t-esc="jour.date"/></h5>
                                <table class="table table-sm table-bordered">
                                    <thead class="bg-light">
                                        <tr>
                                            <th>Plat / Article</th>
                                            <th class="text-center">Quantité (Portions)</th>
                                            <th>Notes spéciales</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="jour.plat_line_ids" t-as="plat">
                                            <tr>
                                                <td><strong t-field="plat.plat_id.name"/> <small class="text-muted">(<t t-esc="plat.plat_type_id.name"/>)</small></td>
                                                <td class="text-center h5 fw-bold"><t t-esc="o.nb_personnes"/></td>
                                                <td><t t-esc="plat.notes or ''"/></td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </t>

                        <!-- Section Logistique -->
                        <h4 class="bg-light p-2 fw-bold mb-3 mt-5"><i class="fa fa-truck me-2"/> MATÉRIEL À CHARGER (LOGISTIQUE)</h4>
                        <table class="table table-sm table-bordered">
                            <thead class="bg-light">
                                <tr>
                                    <th>Élément</th>
                                    <th class="text-center">Quantité</th>
                                    <th class="text-center">État / Check</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="o.logistique_line_ids" t-as="log">
                                    <tr>
                                        <td><t t-esc="log.logistique_id.name"/></td>
                                        <td class="text-center h5 fw-bold"><t t-esc="log.quantite"/></td>
                                        <td class="text-center" style="width: 100px;">[ ]</td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <div class="mt-5 p-3 border rounded">
                            <strong>Commentaires Client :</strong><br/>
                            <p t-field="o.notes_client" class="mb-0"/>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
