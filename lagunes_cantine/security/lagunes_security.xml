<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        
        <!-- Catégorie du module -->
        <record id="module_category_lagunes_cantine" model="ir.module.category">
            <field name="name">Restaurant des Lagunes</field>
            <field name="description">Gestion de la cantine d'entreprise</field>
            <field name="sequence">20</field>
        </record>

        <!-- Groupe : Utilisateur Cantine -->
        <record id="group_lagunes_user" model="res.groups">
            <field name="name">Utilisateur</field>
            <field name="category_id" ref="module_category_lagunes_cantine"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Accès en lecture aux menus et création de commandes</field>
        </record>

        <!-- Groupe : Cuisine / Préparation -->
        <record id="group_lagunes_cuisine" model="res.groups">
            <field name="name">Cuisine</field>
            <field name="category_id" ref="module_category_lagunes_cantine"/>
            <field name="implied_ids" eval="[(4, ref('group_lagunes_user')), (4, ref('lagunes_market.group_market_user'))]"/>
            <field name="comment">Accès aux commandes pour préparation et consultation des stocks</field>
        </record>

        <!-- Groupe : Manager Cantine -->
        <record id="group_lagunes_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="category_id" ref="module_category_lagunes_cantine"/>
            <field name="implied_ids" eval="[(4, ref('group_lagunes_cuisine')), (4, ref('lagunes_market.group_market_user'))]"/>
            <field name="comment">Gestion complète des menus, plats et commandes</field>
        </record>

        <!-- Règles d'enregistrement : Isolation multi-société (company_id)
             NOTE: Les employés cantine s'authentifient via session custom,
             PAS via des comptes Odoo. L'isolation inter-entreprise se fait
             donc dans les controllers (filtrage par session entreprise_id).
             Ces rules protègent uniquement les utilisateurs Odoo internes. -->
        <record id="lagunes_commande_company_rule" model="ir.rule">
            <field name="name">Commande: multi-société</field>
            <field name="model_id" ref="model_lagunes_commande"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('group_lagunes_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Règle pour les managers : accès total -->
        <record id="lagunes_commande_manager_rule" model="ir.rule">
            <field name="name">Commande: manager accès total</field>
            <field name="model_id" ref="model_lagunes_commande"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_lagunes_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Règle pour la cuisine : lecture/écriture des commandes -->
        <record id="lagunes_commande_cuisine_rule" model="ir.rule">
            <field name="name">Commande: cuisine lecture/écriture</field>
            <field name="model_id" ref="model_lagunes_commande"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_lagunes_cuisine'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Règles pour la facturation : isolation multi-entreprise -->
        <record id="lagunes_facturation_periode_company_rule" model="ir.rule">
            <field name="name">Facturation: multi-entreprise</field>
            <field name="model_id" ref="model_lagunes_facturation_periode"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('group_lagunes_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="lagunes_facturation_periode_manager_rule" model="ir.rule">
            <field name="name">Facturation: manager accès total</field>
            <field name="model_id" ref="model_lagunes_facturation_periode"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_lagunes_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

    </data>
</odoo>
