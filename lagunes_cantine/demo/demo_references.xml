<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="0">

    <!-- ═══════════════════════════════════════════════════════════════════
         CATÉGORIES DE MENUS ADDITIONNELLES
         (complètent menu_cat_africain et menu_cat_europeen déjà en data)
         ═══════════════════════════════════════════════════════════════════ -->
    <record id="demo_menu_cat_asiatique" model="lagunes.menu.category">
        <field name="name">Menu Asiatique</field>
        <field name="sequence">3</field>
        <field name="description">Cuisine asiatique (wok, nouilles, sushis).</field>
        <field name="icon">fa-pagelines</field>
        <field name="color">#c0392b</field>
    </record>

    <record id="demo_menu_cat_mediterraneen" model="lagunes.menu.category">
        <field name="name">Menu Méditerranéen</field>
        <field name="sequence">4</field>
        <field name="description">Cuisine méditerranéenne légère et variée.</field>
        <field name="icon">fa-lemon-o</field>
        <field name="color">#16a085</field>
    </record>

    <record id="demo_menu_cat_express" model="lagunes.menu.category">
        <field name="name">Menu Express</field>
        <field name="sequence">5</field>
        <field name="description">Plats rapides et équilibrés, idéaux entre deux réunions.</field>
        <field name="icon">fa-bolt</field>
        <field name="color">#d35400</field>
    </record>

    <record id="demo_menu_cat_bio" model="lagunes.menu.category">
        <field name="name">Menu Bio &amp; Healthy</field>
        <field name="sequence">6</field>
        <field name="description">Plats bio, faibles en matières grasses.</field>
        <field name="icon">fa-leaf</field>
        <field name="color">#27ae60</field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════════
         OPTIONS DE PLAT ADDITIONNELLES
         ═══════════════════════════════════════════════════════════════════ -->
    <record id="demo_plat_option_well_done" model="lagunes.plat.option">
        <field name="name">Cuisson bien cuite</field>
        <field name="sequence">70</field>
        <field name="description">Pour les viandes et poissons, cuisson bien cuite.</field>
        <field name="prix_supplementaire">0.0</field>
        <field name="is_global">True</field>
    </record>

    <record id="demo_plat_option_saignant" model="lagunes.plat.option">
        <field name="name">Cuisson saignante</field>
        <field name="sequence">80</field>
        <field name="description">Cuisson saignante (viandes rouges uniquement).</field>
        <field name="prix_supplementaire">0.0</field>
        <field name="is_global">True</field>
    </record>

    <record id="demo_plat_option_sans_gluten" model="lagunes.plat.option">
        <field name="name">Sans gluten</field>
        <field name="sequence">90</field>
        <field name="description">Préparation adaptée aux régimes sans gluten.</field>
        <field name="prix_supplementaire">0.0</field>
        <field name="is_global">True</field>
    </record>

    <record id="demo_plat_option_sans_lactose" model="lagunes.plat.option">
        <field name="name">Sans lactose</field>
        <field name="sequence">100</field>
        <field name="description">Sans produits laitiers.</field>
        <field name="prix_supplementaire">0.0</field>
        <field name="is_global">True</field>
    </record>

    <record id="demo_plat_option_sauce_piquante" model="lagunes.plat.option">
        <field name="name">Sauce piquante supplémentaire</field>
        <field name="sequence">110</field>
        <field name="description">Un ramequin de piment frais à part.</field>
        <field name="prix_supplementaire">0.0</field>
        <field name="is_global">True</field>
    </record>

