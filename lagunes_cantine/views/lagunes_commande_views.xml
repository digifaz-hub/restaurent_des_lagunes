        </field>
    </record>
    
    <!-- Action : Marquer prêt en masse -->
    <record id="action_bulk_ready" model="ir.actions.server">
        <field name="name">Marquer comme prêt</field>
        <field name="model_id" ref="lagunes_cantine.model_lagunes_commande"/>
        <field name="binding_model_id" ref="lagunes_cantine.model_lagunes_commande"/>
        <field name="state">code</field>
        <field name="code">
if records:
    records.action_bulk_state_change('ready')
        </field>
    </record>
    
    <!-- Action : Marquer livré en masse -->
    <record id="action_bulk_deliver" model="ir.actions.server">
        <field name="name">Marquer comme livré</field>
        <field name="model_id" ref="lagunes_cantine.model_lagunes_commande"/>
        <field name="binding_model_id" ref="lagunes_cantine.model_lagunes_commande"/>
        <field name="state">code</field>
        <field name="code">
if records:
    records.action_bulk_state_change('delivered')
        </field>
    </record>
    
    <!-- Action : Annuler en masse -->
    <record id="action_bulk_cancel" model="ir.actions.server">
        <field name="name">Annuler les commandes</field>
        <field name="model_id" ref="lagunes_cantine.model_lagunes_commande"/>
        <field name="binding_model_id" ref="lagunes_cantine.model_lagunes_commande"/>
        <field name="state">code</field>
        <field name="code">
if records:
    records.action_bulk_state_change('cancelled')
        </field>
    </record>

</odoo>
