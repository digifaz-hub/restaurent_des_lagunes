<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Vue formulaire des périodes de facturation - DESIGN MODERNE -->
    <record id="view_lagunes_facturation_periode_form" model="ir.ui.view">
        <field name="name">lagunes.facturation.periode.form</field>
        <field name="model">lagunes.facturation.periode</field>
        <field name="arch" type="xml">
            <form string=" Période de facturation" class="o_lagunes_view">
                <header>
                    <button name="action_load_commandes" type="object"
                            string=" Charger les commandes"
                            invisible="state != 'draft'"
                            class="btn-secondary"/>
                    <button name="action_confirm" type="object"
                            string=" Confirmer"
                            invisible="state != 'draft'"
                            class="oe_highlight"/>
                    <button name="action_generate_sale_order" type="object"
                            string=" Générer le devis"
                            invisible="state != 'confirmed' or sale_order_id"
                            class="oe_highlight"/>
                    <button name="action_mark_invoiced" type="object"
                            string=" Marquer comme facturé"
                            invisible="state == 'invoiced' or state == 'cancelled' or not invoice_id"
                            class="oe_highlight"
                            confirm="Confirmez-vous que la facture est bien validée (comptabilisée) ?"/>
                    <button name="action_view_sale_order" type="object"
                            string=" Voir le devis"
                            invisible="not sale_order_id"
                            class="btn-primary"/>
                    <button name="action_view_invoice" type="object"
                            string=" Voir la facture"
                            invisible="not invoice_id"
                            class="btn-success"/>
                    <button name="action_cancel" type="object"
                            string=" Annuler"
                            invisible="state in ['invoiced', 'cancelled']"
                            class="btn-warning"
                            confirm="Annuler cette période ? Les commandes 'À facturer' seront remises à 'Non facturée'."/>
                    <button name="action_reset_to_draft" type="object"
                            string=" Remettre en brouillon"
                            invisible="state != 'cancelled'"
                            class="btn-secondary"/>
                    <button name="action_duplicate_next_month" type="object"
                            string=" Dupliquer (mois suivant)"
                            invisible="state not in ['confirmed', 'invoiced']"
                            class="btn-secondary"
                            groups="lagunes_cantine.group_lagunes_manager"/>
                    <button name="%(action_report_facturation_detail)d" type="action" string="Imprimer Justificatif" class="btn-secondary" invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed,invoiced"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_sale_order" type="object"
                                class="oe_stat_button" icon="fa-file-text"
                                invisible="not sale_order_id">
                            <field name="sale_order_id" widget="statinfo" string=" Devis"/>
                        </button>
                        <button name="action_view_invoice" type="object"
                                class="oe_stat_button" icon="fa-money"
                                invisible="not invoice_id">
                            <field name="invoice_id" widget="statinfo" string=" Facture"/>
                        </button>
                    </div>
                    
                    <!-- En-tête moderne -->
                    <div class="oe_title mb-4">
                        <div class="d-flex align-items-center gap-3">
                            <div class="lui-card-icon lui-icon-primary" style="width:60px;height:60px;">
                                <i class="fa fa-money fa-lg" title="Facture"/>
                            </div>
                            <div>
                                <label class="o_form_label" for="name">
                                     Période de facturation
                                </label>
                                <h1 class="mb-0">
                                    <field name="name" readonly="1" class="fw-bold text-primary"/>
                                </h1>
                            </div>
                        </div>
                    </div>
                    
                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="card border-0 bg-light h-100">
                                <div class="card-body">
                                    <h5 class="card-title mb-3">
                                        <i class="fa fa-building text-primary me-2" title="Entreprise"/>
                                        Informations générales
                                    </h5>
                                    <group>
                                        <field name="entreprise_id"
                                               options="{'no_create': True}"
                                               readonly="state != 'draft'"
                                               string=" Entreprise cliente"/>
                                        <field name="company_id"
                                               options="{'no_create': True}"
                                               readonly="1"
                                               string=" Société"/>
                                        <field name="date_start" widget="date" readonly="state != 'draft'"
                                               string=" Date de début"/>
                                        <field name="date_end" widget="date" readonly="state != 'draft'"
                                               string=" Date de fin"/>
                                        <field name="date_facturation" widget="date" readonly="1"
                                               invisible="not date_facturation"
                                               string=" Date de facturation"/>
                                    </group>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="card border-0 bg-light h-100">
                                <div class="card-body">
                                    <h5 class="card-title mb-3">
                                        <i class="fa fa-calculator text-success me-2" title="Calcul"/>
                                        Récapitulatif
                                    </h5>
                                    <group>
                                        <field name="total_commandes" readonly="1" string=" Total commandes"/>
                                        <field name="total_jours" readonly="1" string=" Nombre de jours"/>
                                        <field name="montant_total" readonly="1" widget="monetary"
                                               string=" Montant total" class="h4 fw-bold text-success"/>
                                    </group>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="alert alert-warning d-flex align-items-center gap-2 mt-4" 
                         role="alert" invisible="state != 'draft'">
                        <i class="fa fa-exclamation-triangle" title="Attention"/>
                        <div>
                            <strong>Attention :</strong> Vérifiez qu'aucune autre période active ne chevauche ces dates pour la même entreprise.
                        </div>
                    </div>
                    
                    <notebook class="mt-4">
                        <page string=" Commandes" name="commandes">
                            <div class="alert alert-light border mb-3">
                                <i class="fa fa-info-circle text-primary me-2"/>
                                Liste des commandes incluses dans cette période de facturation. 
                                Les commandes avec le statut "À facturer" seront facturées.
                            </div>
                            <field name="commande_ids" readonly="state not in ['draft', 'confirmed']">
                                <list>
                                    <field name="reference" width="120" string=" Réf."/>
                                    <field name="date" widget="date" width="110" string=" Date"/>
                                    <field name="employee_name" optional="show" width="150" string=" Employé"/>
                                    <field name="entree_plat_id" optional="show" width="130" string=" Entrée"/>
                                    <field name="resistance_plat_id" optional="show" width="130" string=" Plat"/>
                                    <field name="dessert_plat_id" optional="show" width="130" string=" Dessert"/>
                                    <field name="quantity" width="80" string="Qté"/>
                                    <field name="prix_total" sum="Total" widget="monetary" width="120" string=" Total"/>
                                    <field name="state" widget="badge" width="100" string="Statut"/>
                                    <field name="facturation_state" widget="badge" width="100" string="Facturation"
                                           decoration-warning="facturation_state == 'not_invoiced'"
                                           decoration-info="facturation_state == 'to_invoice'"
                                           decoration-success="facturation_state == 'invoiced'"/>
                                </list>
                            </field>
                        </page>
                        <page string=" Notes" name="notes">
                            <div class="alert alert-light border mb-3">
                                <i class="fa fa-lightbulb text-warning me-2"/>
                                Ajoutez des notes qui apparaîtront sur le devis ou la facture
                            </div>
                            <field name="notes"
                                   placeholder="Notes supplémentaires pour la facture..."
                                   readonly="state == 'invoiced'"/>
                        </page>
                        <page string=" Historique" name="chatter">
                            <div class="oe_chatter">
                                <field name="message_follower_ids"/>
                                <field name="activity_ids"/>
                                <field name="message_ids"/>
                            </div>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Vue liste des périodes - DESIGN MODERNE -->
    <record id="view_lagunes_facturation_periode_tree" model="ir.ui.view">
        <field name="name">lagunes.facturation.periode.list</field>
        <field name="model">lagunes.facturation.periode</field>
        <field name="arch" type="xml">
            <list string=" Périodes de facturation"
                  decoration-success="state == 'invoiced'"
                  decoration-info="state == 'confirmed'"
                  decoration-muted="state == 'cancelled'"
                  multi_edit="1"
                  class="o_lagunes_view">
                <!-- Référence et entreprise -->
                <field name="name" width="180" string=" Référence"/>
                <field name="entreprise_id" width="180" string=" Entreprise"/>
                <field name="company_id" optional="show" width="150" string=" Société"/>
                
                <!-- Période -->
                <field name="date_start" widget="date" width="110" string=" Début"/>
                <field name="date_end" widget="date" width="110" string=" Fin"/>
                <field name="total_jours" width="80" string=" Jours"/>
                
                <!-- Totaux -->
                <field name="total_commandes" sum="Total" width="100" string=" Cmds"/>
                <field name="montant_total" sum="Total" widget="monetary" width="140" string=" Montant"/>
                <field name="date_facturation" widget="date" optional="show" width="120" string=" Facturé le"/>
                
                <!-- Statut -->
                <field name="state" widget="badge" width="120" string=" Statut"
                       decoration-success="state == 'invoiced'"
                       decoration-info="state == 'confirmed'"
                       decoration-warning="state == 'draft'"
                       decoration-danger="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <!-- Vue kanban des périodes - DESIGN MODERNE -->
    <record id="view_lagunes_facturation_periode_kanban" model="ir.ui.view">
        <field name="name">lagunes.facturation.periode.kanban</field>
        <field name="model">lagunes.facturation.periode</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_small_column o_lagunes_view" default_group_by="state">
                <field name="id"/>
                <field name="name"/>
                <field name="entreprise_id"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="total_commandes"/>
                <field name="total_jours"/>
                <field name="montant_total"/>
                <field name="state"/>
                <field name="date_facturation"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click lui-card h-100">
                            <div class="oe_kanban_content">
                                <!-- En-tête -->
                                <div class="o_kanban_record_top mb-3">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title text-primary">
                                            <field name="name"/>
                                        </strong>
                                        <span class="o_kanban_record_subtitle text-muted small">
                                            <i class="fa fa-building me-1" title="Entreprise"/>
                                            <field name="entreprise_id"/>
                                        </span>
                                    </div>
                                </div>
                                
                                <!-- Période -->
                                <div class="o_kanban_record_body mb-3">
                                    <div class="d-flex align-items-center gap-2 text-muted small mb-2">
                                        <i class="fa fa-calendar text-primary" title="Calendrier"/>
                                        <field name="date_start"/> → <field name="date_end"/>
                                    </div>
                                    <div class="d-flex gap-2">
                                        <span class="badge rounded-pill bg-info-subtle text-info">
                                            <i class="fa fa-shopping-cart me-1" title="Commandes"/>
                                            <field name="total_commandes"/> cmds
                                        </span>
                                        <span class="badge rounded-pill bg-secondary-subtle text-secondary">
                                            <i class="fa fa-clock-o me-1" title="Temps"/>
                                            <field name="total_jours"/> jrs
                                        </span>
                                    </div>
                                </div>
                                
                                <!-- Montant -->
                                <div class="o_kanban_record_bottom pt-2 border-top">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <strong class="text-success h5 mb-0">
                                            <field name="montant_total"/> FCFA
                                        </strong>
                                        <span t-if="record.date_facturation.raw_value" class="badge bg-success-subtle text-success small">
                                            <i class="fa fa-check me-1"/>
                                            Facturé
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Vue recherche des périodes - DESIGN MODERNE -->
    <record id="view_lagunes_facturation_periode_search" model="ir.ui.view">
        <field name="name">lagunes.facturation.periode.search</field>
        <field name="model">lagunes.facturation.periode</field>
        <field name="arch" type="xml">
            <search string=" Rechercher dans les périodes">
                <!-- Champs de recherche -->
                <field name="name" string=" Référence"/>
                <field name="entreprise_id" string=" Entreprise"/>
                
                <!-- ════════════════════════════════════════════════════════════════
                     FILTRES PAR STATUT
                ════════════════════════════════════════════════════════════════ -->
                <filter string=" Brouillon" name="draft" domain="[('state', '=', 'draft')]"
                        help="Périodes en cours de préparation"/>
                <filter string=" Confirmé" name="confirmed" domain="[('state', '=', 'confirmed')]"
                        help="Périodes validées, prêtes pour facturation"/>
                <filter string=" Facturé" name="invoiced" domain="[('state', '=', 'invoiced')]"
                        help="Périodes déjà facturées"/>
                <filter string=" Annulé" name="cancelled" domain="[('state', '=', 'cancelled')]"
                        help="Périodes annulées"/>
                
                <!-- ════════════════════════════════════════════════════════════════
                     FILTRES TEMPORELS
                ════════════════════════════════════════════════════════════════ -->
                <separator/>
                <filter string=" Ce mois" name="this_month"
                        domain="[('date_start', '&gt;=', context_today().strftime('%Y-%m-01'))]"
                        help="Périodes démarrant ce mois"/>
                <filter string=" Mois dernier" name="last_month"
                        domain="[('date_start', '&gt;=', (context_today() - relativedelta(months=1)).strftime('%Y-%m-01')),
                                ('date_start', '&lt;', context_today().strftime('%Y-%m-01'))]"
                        help="Périodes du mois précédent"/>
                
                <!-- ════════════════════════════════════════════════════════════════
                     GROUPEMENTS
                ════════════════════════════════════════════════════════════════ -->
                <separator/>
                <group expand="0" string=" Grouper par">
                    <filter string=" Entreprise" name="group_entreprise"
                            context="{'group_by': 'entreprise_id'}"/>
                    <filter string=" Statut" name="group_state"
                            context="{'group_by': 'state'}"/>
                    <filter string=" Par mois" name="group_month"
                            context="{'group_by': 'date_start:month'}"/>
                    <filter string=" Par semaine" name="group_week"
                            context="{'group_by': 'date_start:week'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action pour la facturation - DESIGN MODERNE -->
    <record id="action_lagunes_facturation_periode" model="ir.actions.act_window">
        <field name="name"> Facturation Mensuelle</field>
        <field name="res_model">lagunes.facturation.periode</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="context">{'search_default_this_month': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Aucune période de facturation</p>
            <div class="p-3 bg-light rounded">
                <h5 class="mb-3"><i class="fa fa-money text-primary me-2" title="Argent"/>Gérez la facturation mensuelle</h5>
                <p>Regroupez les commandes par entreprise et par période pour générer des devis et factures.</p>
                
                <div class="row g-3 mb-3">
                    <div class="col-md-3">
                        <div class="d-flex align-items-start gap-2">
                            <i class="fa fa-plus-circle text-success mt-1" title="Créer"/>
                            <div>
                                <strong>1. Créer</strong>
                                <p class="small text-muted mb-0">Définissez la période</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="d-flex align-items-start gap-2">
                            <i class="fa fa-download text-info mt-1" title="Charger"/>
                            <div>
                                <strong>2. Charger</strong>
                                <p class="small text-muted mb-0">Importez les commandes</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="d-flex align-items-start gap-2">
                            <i class="fa fa-check-circle text-primary mt-1" title="Confirmer"/>
                            <div>
                                <strong>3. Confirmer</strong>
                                <p class="small text-muted mb-0">Validez la période</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="d-flex align-items-start gap-2">
                            <i class="fa fa-file-text-o text-warning mt-1" title="Devis"/>
                            <div>
                                <strong>4. Facturer</strong>
                                <p class="small text-muted mb-0">Générez le devis</p>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="alert alert-info mb-0 py-2">
                    <i class="fa fa-lightbulb text-warning me-2"/>
                    <strong>Workflow :</strong> Brouillon → Confirmé → Devis généré → Facturé
                </div>
            </div>
        </field>
    </record>

    <!-- NOTE : le menuitem est défini dans lagunes_menus.xml -->

</odoo>