                                                                            <span class="badge bg-warning text-dark" style="font-size: 7px;"><t t-esc="pt_hm_d.name"/></span>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </t>
                                                    </t>
                                                </t>
                                            </div>
                                        </div>
                                    </t>

                                    <div class="mt-5 text-end">
                                        <button class="btn btn-lg btn-primary px-5 shadow-sm btn-next-step" disabled="disabled" style="border-radius: 10px; font-weight: 600;">
                                            Suivant <i class="fa fa-chevron-right ms-2"/>
                                        </button>
                                    </div>
                                </section>

                                <!-- STEP 2: OPTIONS &amp; PERSONNALISATION -->
                                <section class="wizard-step" id="step-2">
                                    <div class="step-header mb-4">
                                        <button class="btn btn-link btn-sm p-0 mb-3 text-decoration-none btn-prev-step" style="color: #16166d; font-weight: 600;">
                                            <i class="fa fa-arrow-left me-1"/> Retour au choix du plat
                                        </button>
                                        <h3 class="fw-bold" style="color: #16166d;">2. Personnalisation</h3>
                                        <p class="text-muted">Ajustez votre plat selon vos envies.</p>
                                    </div>

                                    <div id="plat-options-container" class="mb-4">
