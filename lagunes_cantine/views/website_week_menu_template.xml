                                    </div>

                                    <div class="mb-4">
                                        <label class="form-label fw-bold small text-uppercase" style="color: #16166d; letter-spacing: 1px;">Notes &amp; Préférences</label>
                                        <textarea class="form-control border-0 bg-light p-3" id="wizard-notes" rows="3" placeholder="Ex: Sans sel, piment à part, etc..." style="border-radius: 12px;"></textarea>
                                    </div>

                                    <div class="mt-5 d-flex justify-content-between">
                                        <button class="btn btn-prev-step px-4">
                                            <i class="fa fa-arrow-left me-2"/>Précédent
                                        </button>
                                        <button class="btn btn-primary px-5 shadow-sm btn-next-step" style="border-radius: 10px; font-weight: 600;">
                                            Vérifier <i class="fa fa-chevron-right ms-2"/>
                                        </button>
                                    </div>
                                </section>

                                <!-- STEP 3: RÉCAPITULATIF -->
                                <section class="wizard-step" id="step-3">
                                    <div class="step-header mb-5 text-center">
                                        <h3 class="fw-bold" style="color: #16166d;">Votre Sélection</h3>
                                        <p class="text-muted">Prêt à passer en cuisine ?</p>
                                    </div>

                                    <div class="row justify-content-center">
                                        <div class="col-lg-7">
                                            <div class="card shadow-lg border-0 mb-4" style="border-radius: 20px;">
                                                <div class="card-body p-4">
                                                    <div id="wizard-recap-details"></div>

                                                    <t t-if="peut_commander_pour_autres">
                                                        <hr class="my-4 opacity-50"/>
                                                        <div class="form-check form-switch mb-2">
                                                            <input class="form-check-input" type="checkbox" id="order-for-other-check"/>
                                                            <label class="form-check-label fw-bold small text-muted" for="order-for-other-check">COMMANDER POUR UN COLLÈGUE</label>
                                                        </div>
                                                        <div id="order-for-other-input" class="mt-2 d-none">
                                                            <input type="text" id="order-for-other-name" class="form-control border-0 bg-light" placeholder="Nom complet" style="border-radius: 8px;"/>
                                                        </div>
                                                    </t>
                                                </div>
                                            </div>

                                            <button class="btn btn-success btn-lg w-100 py-3 shadow" id="btn-final-submit" style="border-radius: 15px; font-weight: 700; letter-spacing: 0.5px;">
                                                COMMANDER MAINTENANT
                                            </button>
                                            <div id="wizard-feedback" class="mt-3 text-center d-none"></div>
                                        </div>
                                    </div>

                                    <div class="mt-4 text-center">
                                        <button class="btn btn-link btn-prev-step text-decoration-none small" style="color: #16166d; font-weight: 600;">
                                            <i class="fa fa-pencil me-1"/> Modifier ma sélection
                                        </button>
                                    </div>
                                </section>
                            </div>
                        </t>

                        <t t-else="">
                            <div class="text-center py-5 bg-white rounded-lg shadow-sm border">
                                <i class="fa fa-lock fa-4x mb-3 opacity-25 text-primary" title="Accès restreint"/>
                                <h4 class="fw-bold">Accès restreint</h4>
                                <p class="text-muted px-4">
                                    <t t-if="heure_limite_atteinte">Le service de commande est fermé pour aujourd'hui.</t>
                                    <t t-else="">Limite quotidienne de commande atteinte.</t>
                                </p>
                                <a href="/cantine/commandes/list" class="btn btn-primary px-4 mt-3 rounded-pill">Mes Commandes</a>
                            </div>
                        </t>

                    </main>

                </div>
            </div>
        </div>

        <script type="module" src="/lagunes_cantine/static/src/js/week_menu.js"/>
    </t>
