<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════════════════════════
         VUE FORMULAIRE DU WIZARD DE WARNING STOCK INSUFFISANT
    ═══════════════════════════════════════════════════════════════════════ -->
    <record id="view_stock_insufficient_warning_form" model="ir.ui.view">
        <field name="name">lagunes.stock.insufficient.warning.form</field>
        <field name="model">lagunes.stock.insufficient.warning</field>
        <field name="arch" type="xml">
            <form string="⚠️ Stock insuffisant détecté">
                <!-- En-tête avec alerte visuelle -->
                <div class="alert alert-danger mb-3" role="alert">
                    <div class="d-flex align-items-center gap-3">
                        <i class="fa fa-exclamation-triangle fa-2x" title="Attention"/>
                        <div>
                            <h4 class="alert-heading mb-1">Stock insuffisant pour valider ces commandes</h4>
                            <p class="mb-0">
                                Certains articles n'ont pas suffisamment de stock pour honorer toutes les commandes sélectionnées.
                            </p>
                        </div>
                    </div>
                </div>

                <sheet>
                    <!-- Résumé des commandes concernées -->
                    <group>
                        <field name="commande_ids" widget="many2many_tags" string="Commandes concernées"/>
                        <field name="new_state" invisible="1"/>
                    </group>

                    <!-- Tableau des manquants -->
                    <div class="mt-3 mb-3">
                        <h5>
                            <i class="fa fa-list-alt me-2" title="Détails"/>
                            Détails des articles manquants
                        </h5>
                        <field name="warning_line_ids" nolabel="1" readonly="1">
                            <list decoration-danger="is_critical" decoration-warning="not is_critical">
                                <field name="article_name" string="Article" width="200"/>
                                <field name="requested_qty" string="Demandé" width="120"/>
                                <field name="available_qty" string="Disponible" width="120"/>
                                <field name="missing_qty" string="Manquant" width="120"/>
                                <field name="unit" string="Unité" width="80"/>
                                <field name="is_critical" string="Rupture" widget="boolean_toggle" optional="show"/>
                            </list>
                        </field>
                    </div>

                    <!-- Indicateurs -->
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <field name="can_proceed" invisible="1"/>
                            <div class="alert alert-warning" invisible="can_proceed" role="status">
                                <i class="fa fa-ban me-2" title="Interdit"/>
                                <strong>Impossible de continuer :</strong>
                                Au moins un article est totalement en rupture (stock = 0).
                            </div>
                            <div class="alert alert-info" invisible="not can_proceed" role="status">
                                <i class="fa fa-info-circle me-2" title="Info"/>
                                <strong>Continuation possible :</strong>
                                Tous les articles ont au moins un peu de stock, mais certains seront partiellement servis.
                            </div>
                        </div>
                        <div class="col-md-6">
                            <field name="has_critical" invisible="1"/>
                            <div class="alert alert-danger" invisible="not has_critical" role="alert">
                                <i class="fa fa-exclamation-circle me-2" title="Critique"/>
                                <strong>Attention rupture :</strong>
                                Des articles sont totalement épuisés.
                            </div>
                        </div>
                    </div>

                    <!-- Options de forçage -->
                    <group string="Options de forçage" invisible="not can_proceed">
                        <field name="force_reason" nolabel="1"
                               placeholder="Justification obligatoire (min 10 caractères) : pourquoi forcez-vous malgré le stock insuffisant ?"/>
                        <field name="notify_manager"/>
                    </group>

                    <!-- Résumé texte -->
                    <group>
                        <field name="summary_text" nolabel="1" readonly="1"/>
                    </group>
                </sheet>

                <!-- Footer avec boutons -->
                <footer>
                    <!-- Bouton Continuer - visible seulement si can_proceed -->
                    <button name="action_force_continue" type="object"
                            string="Continuer malgré tout" class="btn btn-warning"
                            invisible="not can_proceed"
                            confirm="Êtes-vous sûr de vouloir continuer avec un stock insuffisant ? Cette action sera tracée."/>

                    <!-- Bouton Annuler -->
                    <button special="cancel" string="Annuler" class="btn btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════════════
         ACTION POUR OUVRIR LE WIZARD
    ═══════════════════════════════════════════════════════════════════════ -->
    <record id="action_stock_insufficient_warning" model="ir.actions.act_window">
        <field name="name">⚠️ Stock insuffisant</field>
        <field name="res_model">lagunes.stock.insufficient.warning</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
