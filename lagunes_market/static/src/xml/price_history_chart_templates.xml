<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="lagunes_market.PriceHistoryChart">
        <div class="o_price_history_chart_container bg-white rounded-4 p-3 border" style="height: 300px; width: 100%;">
            <t t-if="!props.record.data.price_history_json or JSON.parse(props.record.data.price_history_json).length === 0">
                <div class="d-flex flex-column align-items-center justify-content-center h-100 text-muted">
                    <i class="fa fa-line-chart fa-3x mb-3 opacity-25"/>
                    <p>Aucun historique de prix disponible pour cet article.</p>
                </div>
            </t>
            <t t-else="">
                <canvas t-ref="chart"/>
            </t>
        </div>
    </t>
</templates>
