<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Catégories -->
        <record id="uom_categ_weight" model="lagunes.market.uom.category">
            <field name="name">Poids (Masse)</field>
        </record>

        <record id="uom_categ_vol" model="lagunes.market.uom.category">
            <field name="name">Volume (Liquides)</field>
        </record>

        <record id="uom_categ_unit" model="lagunes.market.uom.category">
            <field name="name">Unité (Compte)</field>
        </record>

        <!-- Unités : POIDS -->
        <record id="uom_kg" model="lagunes.market.uom">
            <field name="name">kg</field>
            <field name="category_id" ref="uom_categ_weight"/>
            <field name="uom_type">reference</field>
            <field name="factor">1.0</field>
        </record>

        <record id="uom_g" model="lagunes.market.uom">
            <field name="name">g</field>
            <field name="category_id" ref="uom_categ_weight"/>
            <field name="uom_type">smaller</field>
            <field name="factor">1000.0</field> <!-- Dans Odoo standard, factor_inv = 1000. Je vais utiliser factor pour MULTIPLIER la quantité d'unité de référence pour obtenir la sous-unité, ou Division? -->
            <!-- 
                Attention : Pour Odoo, 1 kg = 1000g. 
                Si Qty_Ref = 1, Qty_g = Qty_Ref * factor.
                Je vais suivre la logique Odoo : 
                - Reference : factor = 1.0
                - Bigger than reference : factor = ratio de combien d'unités de référence dans CETTE unité (ex: Tonne = 1000 kg).
                - Smaller than reference : factor = ratio de combien de CETTE unité dans l'unité de référence (ex: g = 1000 dans 1 kg).
            -->
        </record>

        <record id="uom_mg" model="lagunes.market.uom">
            <field name="name">mg</field>
            <field name="category_id" ref="uom_categ_weight"/>
            <field name="uom_type">smaller</field>
            <field name="factor">1000000.0</field>
        </record>

