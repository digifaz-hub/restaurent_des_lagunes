<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Catégorie de sécurité du module -->
        <record id="module_lagunes_market" model="ir.module.category">
            <field name="name">Gestion des marchés</field>
            <field name="description">Module de gestion des marchés d'approvisionnement</field>
            <field name="sequence">50</field>
        </record>

        <!-- Groupe : Utilisateur marché -->
        <record id="group_market_user" model="res.groups">
            <field name="name">Utilisateur</field>
            <field name="category_id" ref="module_lagunes_market"/>
            <field name="comment">Peut lire, créer et modifier les marchés. Ne peut pas supprimer ni accéder à la configuration.</field>
        </record>

        <!-- Groupe : Gestionnaire marché (hérite de l'utilisateur) -->
        <record id="group_market_manager" model="res.groups">
            <field name="name">Gestionnaire</field>
            <field name="category_id" ref="module_lagunes_market"/>
            <field name="implied_ids" eval="[(4, ref('group_market_user'))]"/>
            <field name="comment">Accès complet : tous droits + configuration comptable.</field>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>

        <record id="rule_lagunes_market_multi_company" model="ir.rule">
            <field name="name">Marché - Multi Company</field>
            <field name="model_id" ref="model_lagunes_market"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="rule_lagunes_market_stock_multi_company" model="ir.rule">
            <field name="name">Stock Marché - Multi Company</field>
            <field name="model_id" ref="model_lagunes_market_stock"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>

        <record id="rule_lagunes_market_stock_move_multi_company" model="ir.rule">
            <field name="name">Mouvements Stock - Multi Company</field>
            <field name="model_id" ref="model_lagunes_market_stock_move"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>
    </data>
</odoo>
