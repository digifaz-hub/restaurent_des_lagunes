<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_market_adjustment_wizard_form" model="ir.ui.view">
        <field name="name">lagunes.market.adjustment.wizard.form</field>
        <field name="model">lagunes.market.adjustment.wizard</field>
        <field name="arch" type="xml">
            <form string="Ajustement Manuel">
                <sheet>
                    <p class="text-muted">
                        Saisissez la quantité à ajuster (ex: +5 pour ajouter, -3 pour retirer) et la raison de cet ajustement.
                    </p>
                    <group>
                        <field name="stock_id" readonly="1"/>
                        <field name="qty_delta"/>
                        <field name="reason" placeholder="ex: Erreur d'inventaire, casse..."/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_apply" type="object" string="Appliquer" class="btn-primary"/>
                    <button special="cancel" string="Annuler" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
