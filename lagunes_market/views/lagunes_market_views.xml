<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ═══════════════════════════════════════════════════════════
         FORMULAIRE MARCHÉ
    ═══════════════════════════════════════════════════════════ -->
    <record id="view_market_form" model="ir.ui.view">
        <field name="name">lagunes.market.form</field>
        <field name="model">lagunes.market</field>
        <field name="arch" type="xml">
            <form string="Marché d'approvisionnement">
                <header>
                    <button name="action_validate" type="object"
                            string="Valider" class="btn-primary"
                            invisible="state != 'draft'"
                            confirm="Êtes-vous sûr de vouloir valider ce marché ? Le stock sera mis à jour (stock initial + achats) et une écriture comptable sera créée."/>
                    <button name="action_cancel" type="object"
                            string="Annuler"
                            class="btn-secondary"
                            invisible="state == 'cancelled'"
                            confirm="Annuler ce marché ? Si validé, le stock et l'écriture comptable seront remis à jour."/>
                    <button name="action_reset_draft" type="object"
                            string="Remettre en brouillon"
                            invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,validated"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_move" type="object"
                                class="oe_stat_button" icon="fa-book"
                                invisible="not move_id">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_text">Écriture</span>
                                <span class="o_stat_text">comptable</span>
                            </div>
                        </button>
                        <button name="action_open_stock_moves" type="object"
                                class="oe_stat_button" icon="fa-exchange"
                                invisible="state == 'draft'">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_text">Mouvements</span>
                                <span class="o_stat_text">de stock</span>
                            </div>
                        </button>
                    </div>

                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Informations générales">
                            <field name="date"/>
                            <field name="user_id"/>
                            <field name="company_id" groups="base.group_multi_company" readonly="1" force_save="1"/>
                        </group>
                        <group string="Montant">
                            <field name="amount_total" widget="monetary"
                                   readonly="1"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>

                    <notebook>
                        <!-- ─── Onglet 1 : Articles achetés ─────────── -->
                        <page string="Articles achetés" name="lines">
                            <field name="line_ids" widget="one2many_list"
                                   readonly="state != 'draft'">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="article_id" domain="[('active', '=', True)]"/>
                                    <field name="category_id" optional="show"/>
                                    <field name="qty"/>
                                    <field name="unit_price" optional="show"/>
                                    <field name="subtotal" optional="show" readonly="1"/>
                                    <field name="uom_id" string="Unité" options="{'no_open': True, 'no_create': True}"/>
                                    <field name="stock_before" optional="show"
                                           string="Stock avant"
                                           readonly="1"/>
                                    <field name="stock_after" optional="show"
                                           string="Stock après"
                                           decoration-success="qty > 0"
                                           readonly="1"/>
                                </list>
                            </field>
                        </page>

                        <!-- ─── Onglet 2 : Stock initial du marché ─── -->
                        <page string="Stock initial" name="leftovers">
                            <!-- Bandeau explicatif -->
                            <div class="alert alert-info" role="alert"
                                 invisible="state != 'draft'">
                                <strong>Comment ça marche ?</strong>
                                Indiquez ici le stock initial (reste du marché précédent)
                                avec la quantité réelle restante.
                                À la validation, ces quantités seront <strong>remplacées</strong>
                                dans le stock, puis les nouveaux achats seront ajoutés.
                                Utilisez le bouton <em>Pré-remplir depuis le stock actuel</em>
                                pour gagner du temps.
                            </div>

                            <!-- Bouton pré-remplissage -->
                            <div class="mb-3" invisible="state != 'draft'">
                                <button name="action_prefill_leftovers" type="object"
                                        string="↺  Pré-remplir depuis le stock actuel"
                                        class="btn btn-secondary"
                                        confirm="Cette action remplacera le stock initial déjà saisi. Continuer ?"/>
                            </div>

                            <field name="leftover_ids" widget="one2many_list"
                                   readonly="state != 'draft'">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="article_id" domain="[('active', '=', True)]"/>
                                    <field name="category_id" optional="show"/>
                                    <field name="stock_current"
                                           string="Stock actuel"
                                           readonly="1"
                                           optional="show"/>
                                    <field name="qty_remaining"
                                           string="Quantité restante"
                                           decoration-warning="qty_remaining == 0"
                                           decoration-success="qty_remaining &gt; 0"/>
                                    <field name="uom_id" string="Unité" options="{'no_open': True, 'no_create': True}"/>
                                </list>
                            </field>

                            <!-- Résumé stock initial -->
                            <group invisible="not leftover_ids">
                                <div class="o_td_label">
                                    <span class="o_form_label">Articles en stock initial</span>
                                </div>
                            </group>
                        </page>

                        <!-- ─── Onglet 3 : Notes ─────────────────────── -->
                        <page string="Notes" name="notes">
                            <field name="notes" placeholder="Observations, remarques sur ce marché…"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════
         LISTE MARCHÉS
    ═══════════════════════════════════════════════════════════ -->
    <record id="view_market_list" model="ir.ui.view">
        <field name="name">lagunes.market.list</field>
        <field name="model">lagunes.market</field>
        <field name="arch" type="xml">
            <list string="Marchés" decoration-success="state == 'validated'"
                  decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="date"/>
                <field name="user_id"/>
                <field name="amount_total" sum="Total" widget="monetary"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="state" widget="badge"
                       decoration-warning="state == 'draft'"
                       decoration-success="state == 'validated'"
                       decoration-danger="state == 'cancelled'"/>
                <field name="move_id" string="Écriture comptable" optional="show"/>
            </list>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════
         KANBAN MARCHÉS
    ═══════════════════════════════════════════════════════════ -->
    <record id="view_market_kanban" model="ir.ui.view">
        <field name="name">lagunes.market.kanban</field>
        <field name="model">lagunes.market</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="name"/>
                <field name="date"/>
                <field name="user_id"/>
                <field name="amount_total"/>
                <field name="currency_id"/>
                <field name="state"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                </div>
                                <div class="o_kanban_record_top_right">
                                    <field name="state" widget="badge"
                                           decoration-warning="state == 'draft'"
                                           decoration-success="state == 'validated'"
                                           decoration-danger="state == 'cancelled'"/>
                                </div>
                            </div>
                            <div class="o_kanban_record_body">
                                <div><i class="fa fa-calendar" title="Date du marché"/> <field name="date"/></div>
                                <div><i class="fa fa-user" title="Responsable"/> <field name="user_id"/></div>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_right">
                                    <strong>
                                        <field name="amount_total" widget="monetary"/>
                                    </strong>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════
         RECHERCHE MARCHÉS
    ═══════════════════════════════════════════════════════════ -->
    <record id="view_market_search" model="ir.ui.view">
        <field name="name">lagunes.market.search</field>
        <field name="model">lagunes.market</field>
        <field name="arch" type="xml">
            <search string="Recherche marchés">
                <field name="name" string="Référence"/>
                <field name="user_id" string="Responsable"/>
                <filter name="draft" string="Brouillon"
                        domain="[('state', '=', 'draft')]"/>
                <filter name="validated" string="Validé"
                        domain="[('state', '=', 'validated')]"/>
                <filter name="cancelled" string="Annulé"
                        domain="[('state', '=', 'cancelled')]"/>
                <separator/>
                <filter name="this_month" string="Ce mois-ci"
                        domain="[('date', '&gt;=', (context_today()).strftime('%Y-%m-01'))]"/>
                <group expand="0" string="Regrouper par">
                    <filter name="group_state" string="Statut"
                            context="{'group_by': 'state'}"/>
                    <filter name="group_user" string="Responsable"
                            context="{'group_by': 'user_id'}"/>
                    <filter name="group_month" string="Mois"
                            context="{'group_by': 'date:month'}"/>
                    <filter name="group_year" string="Année"
                            context="{'group_by': 'date:year'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════
         PIVOT — Analyse des dépenses
    ═══════════════════════════════════════════════════════════ -->
    <record id="view_market_pivot" model="ir.ui.view">
        <field name="name">lagunes.market.pivot</field>
        <field name="model">lagunes.market</field>
        <field name="arch" type="xml">
            <pivot string="Analyse des dépenses" disable_linking="False">
                <field name="date" type="row" interval="month"/>
                <field name="user_id" type="col"/>
                <field name="amount_total" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════
         GRAPHIQUE — Dépenses par mois (barres)
    ═══════════════════════════════════════════════════════════ -->
    <record id="view_market_graph" model="ir.ui.view">
        <field name="name">lagunes.market.graph</field>
        <field name="model">lagunes.market</field>
        <field name="arch" type="xml">
            <graph string="Dépenses par mois" type="bar">
                <field name="date" interval="month"/>
                <field name="amount_total" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════
         CALENDRIER — Vue planning des marchés
    ═══════════════════════════════════════════════════════════ -->
    <record id="view_market_calendar" model="ir.ui.view">
        <field name="name">lagunes.market.calendar</field>
        <field name="model">lagunes.market</field>
        <field name="arch" type="xml">
            <calendar string="Planning des marchés" date_start="date" color="user_id">
                <field name="name"/>
                <field name="user_id" avatar_field="avatar_128"/>
                <field name="amount_total"/>
                <field name="state"/>
            </calendar>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════
         ACTIONS
    ═══════════════════════════════════════════════════════════ -->
    <record id="action_market" model="ir.actions.act_window">
        <field name="name">Tous les marchés</field>
        <field name="res_model">lagunes.market</field>
        <field name="view_mode">list,kanban,calendar,form,pivot,graph</field>
        <field name="search_view_id" ref="view_market_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Créer votre premier marché d'approvisionnement
            </p>
            <p>
                Enregistrez chaque sortie au marché, les articles achetés,
                déclarez le stock initial du marché précédent et suivez vos dépenses.
            </p>
        </field>
    </record>

    <record id="view_market_line_search" model="ir.ui.view">
        <field name="name">lagunes.market.line.search</field>
        <field name="model">lagunes.market.line</field>
        <field name="arch" type="xml">
            <search string="Recherche lignes de marché">
                <field name="article_id"/>
                <field name="market_id"/>
                <group expand="0" string="Regrouper par">
                    <filter name="group_market" string="Marché"
                            context="{'group_by': 'market_id'}"/>
                    <filter name="group_article" string="Article"
                            context="{'group_by': 'article_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_market_analysis" model="ir.actions.act_window">
        <field name="name">Dépenses par mois</field>
        <field name="res_model">lagunes.market</field>
        <field name="view_mode">graph,pivot,list</field>
        <field name="domain">[('state', '=', 'validated')]</field>
        <field name="search_view_id" ref="view_market_search"/>
        <field name="context">{'search_default_group_month': 1}</field>
    </record>
</odoo>