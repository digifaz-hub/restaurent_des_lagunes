              parent="menu_market_root"
              action="lagunes_market.action_market_dashboard"
              sequence="5"
              groups="lagunes_market.group_market_user"/>

    <!-- ─── Marchés ─────────────────────────────────────────── -->
    <menuitem id="menu_market_markets"
              name="Marchés"
              parent="menu_market_root"
              sequence="10"
              groups="lagunes_market.group_market_user"/>

    <menuitem id="menu_market_all"
              name="Tous les marchés"
              parent="menu_market_markets"
              action="lagunes_market.action_market"
              sequence="10"
              groups="lagunes_market.group_market_user"/>

    <menuitem id="menu_market_leftover"
              name="Stock initial (consultation)"
              parent="menu_market_markets"
              action="lagunes_market.action_market_leftover"
